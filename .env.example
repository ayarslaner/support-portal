# ── Server ──────────────────────────────────────────
PORT=3000

# ── Internal API Authentication ─────────────────────
# Change this to a strong, random secret before deployment
INTERNAL_API_KEY=change-me-to-a-secure-random-key-abc123

# ── SMTP / Email Configuration ──────────────────────
# Leave defaults to disable email (warnings will be logged)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=support@yourcompany.com
SMTP_PASS=your-smtp-password
SMTP_FROM="Support Team <support@yourcompany.com>"

# ── SLA Configuration ──────────────────────────────
# Hours of inactivity before an SLA alert fires
SLA_THRESHOLD_HOURS=24
# Email address(es) for SLA breach alerts (comma-separated)
SLA_ALERT_EMAIL=management@yourcompany.com
# Cron expression for SLA check frequency (default: every hour)
SLA_CRON_SCHEDULE=0 * * * *
